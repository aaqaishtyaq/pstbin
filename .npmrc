# Supply-chain defense: only install package versions published ≥ 7 days ago.
# Most malicious publishes are yanked within hours; a week of aging blocks them.
#
# Critical vulns: when npm audit fix is blocked by this window, either:
#   1. npm run deps:allow-critical   # auto-exclude packages with critical advisories
#   2. or add manually:
#        min-release-age-exclude[]=package-name
# then re-run npm install / npm audit fix.
min-release-age=7
