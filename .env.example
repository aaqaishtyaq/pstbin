# Copy to .env.local for local overrides (not committed).
# On Vercel/Netlify/etc., set the same keys in the project environment.

# ── Branding (inlined into the client at build time) ───────────────────────
NEXT_PUBLIC_SITE_NAME=pstbin
# NEXT_PUBLIC_SITE_NAME_UPPER=PSTBIN
NEXT_PUBLIC_SITE_TITLE=pstbin(1)
NEXT_PUBLIC_SITE_DESCRIPTION=Client-side pastebin. Data lives in the URL. curl POST supported — nothing stored on the server.
NEXT_PUBLIC_SITE_TAGLINE=client-side pastebin. data lives in the URL.
NEXT_PUBLIC_REPO_URL=https://github.com/aaqaishtyaq/pstbin
NEXT_PUBLIC_CANONICAL_URL=https://paste.aaqa.dev

# ── Server ─────────────────────────────────────────────────────────────────
# Force origin printed by curl POST (optional; usually auto-detected)
# PSTBIN_PUBLIC_URL=https://paste.aaqa.dev

# Max upload size for POST /api (bytes)
# PSTBIN_MAX_PASTE_BYTES=1500000
